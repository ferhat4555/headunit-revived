<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_projection_blue"
    android:gravity="center">

    <LinearLayout
        android:id="@+id/branding_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/splash_logo"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:src="@mipmap/ic_launcher_playstore" />

        <TextView
            android:id="@+id/text_headunit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="-10dp"
            android:text="Headunit"
            android:textAllCaps="false"
            android:textColor="@color/splash_text_white"
            android:textSize="35sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text_revived"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="-4dp"
            android:text="REVIVED"
            android:textAllCaps="true"
            android:textColor="@color/splash_text_revived"
            android:textSize="35sp"
            android:textStyle="bold" />

    </LinearLayout>

</RelativeLayout>
